# Secrets -- never commit these. The harness injects real values at
# evaluation time; .env is for local testing only.
.env

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local test output (regenerated by scripts/run_local.sh)
data/results.json

# ONNX sentiment model (123MB -- over GitHub's 100MB limit; the Dockerfile
# downloads it from the HF hub at image build time instead)
local_models/

# Presentation material -- not part of the submission code
Text.txt
*.pptx

# OS cruft
.DS_Store

# Unrelated local tooling artifact, not part of this project
.claude-flow/

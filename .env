# Local development only. The real harness injects these at evaluation time --
# do NOT bundle this file in the Docker image (.dockerignore already excludes it).

FIREWORKS_API_KEY=fw_2q27ShH69QkZqUVHkfW8Nx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Comma-separated, no spaces. Use real Fireworks model IDs you have access to
# for local testing -- the harness will overwrite this with the official
# ALLOWED_MODELS list on launch day; your code must never hardcode a model ID.
ALLOWED_MODELS=accounts/fireworks/models/llama-v3p1-8b-instruct,accounts/fireworks/models/llama-v3p1-70b-instruct

# Local-testing-only overrides (the container defaults to /input/tasks.json
# and /output/results.json, which is what the harness expects):
TASKS_INPUT_PATH=./data/tasks.json
TASKS_OUTPUT_PATH=./data/results.json

MAX_CONCURRENCY=6
ALLOWED_MODELS=accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/glm-5p1,accounts/fireworks/models/deepseek-v4-pro,accounts/fireworks/models/kimi-k2p6,accounts/fireworks/models/kimi-k2p5,accounts/fireworks/models/glm-5p2
CHEAP_MODEL_OVERRIDE=accounts/fireworks/models/gpt-oss-120b
STRONG_MODEL_OVERRIDE=accounts/fireworks/models/glm-5p2

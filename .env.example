# Local development only. The real harness injects these at evaluation time --
# do NOT bundle this file in the Docker image (.dockerignore already excludes it).

FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Comma-separated, no spaces. Real models from `curl .../v1/models` with your
# key (excludes flux-1-schnell-fp8, which is image-gen only, supports_chat=false).
# The harness will overwrite this with the official ALLOWED_MODELS list on
# launch day -- your code must never hardcode a model ID (it doesn't; see
# CHEAP_MODEL_OVERRIDE/STRONG_MODEL_OVERRIDE below, which are still
# validated against this list at runtime).
ALLOWED_MODELS=accounts/fireworks/models/minimax-m2p7,accounts/fireworks/models/minimax-m3,accounts/fireworks/models/kimi-k2p6,accounts/fireworks/models/kimi-k2p7-code

# Pricing-based overrides (checked July 2026, per-M tokens): MiniMax M3 is
# $0.3 in / $1.2 out (same as M2.7 but bigger context + newer -- prefer it),
# Kimi K2.6/K2.7 Code are $0.95 in / $4 out (same price as each other). None
# of these ids carry a parameter-count token (unlike e.g. "gpt-oss-120b" or
# "llama-v3p1-70b"), so model_select.py's size heuristic can't rank them at
# all -- without these overrides, tiering degenerates to whatever order
# ALLOWED_MODELS happens to list them in.
#
# STRONG_MODEL_OVERRIDE is set to k2p7-code, not k2p6, based on a head-to-
# head test (2026-07-09): k2p6 dumped raw chain-of-thought on a
# logical_reasoning prompt and never reached the required "Answer:" line
# (1628 tokens, cut off mid-sentence -- would fail the accuracy gate).
# k2p7-code answered the same prompt correctly and properly formatted in
# 593 tokens, and also beat k2p6 on math_reasoning (245 vs 399 tokens, same
# correct answer). Same price, so this is a strict improvement, not a
# trade-off. Re-verify this once the official launch-day ALLOWED_MODELS
# models are confirmed -- this was tested against k2p6/k2p7-code specifically.
CHEAP_MODEL_OVERRIDE=accounts/fireworks/models/minimax-m3
STRONG_MODEL_OVERRIDE=accounts/fireworks/models/kimi-k2p7-code
STRONG_CODE_MODEL_OVERRIDE=accounts/fireworks/models/kimi-k2p7-code

# Local-testing-only overrides (the container defaults to /input/tasks.json
# and /output/results.json, which is what the harness expects):
TASKS_INPUT_PATH=./data/tasks.json
TASKS_OUTPUT_PATH=./data/results.json

MAX_CONCURRENCY=6
